{
    "Comment": "A description of my state machine",
    "StartAt": "CreateOrder",
    "States": {
        "CreateOrder": {
            "Type": "Task",
            "Resource": "arn:aws:states:::lambda:invoke",
            "Arguments": {
                "FunctionName": "${create_order_arn}",
                "Payload": "{% $states.input %}"
            },
            "Next": "ChargePayment",
            "Catch": [
                {
                    "ErrorEquals": [
                        "States.ALL"
                    ],
                    "Output": "{% {\"Payload\": $states.input, \"errorDetails\": $states.errorOutput } %}",
                    "Next": "CancelOrder"
                }
            ],
            "Output": "{% $states.result.Payload %}"
        },
        "CancelOrder": {
            "Type": "Task",
            "Resource": "arn:aws:states:::lambda:invoke",
            "Arguments": {
                "FunctionName": "${cancel_order_arn}",
                "Payload": "{% $states.input %}"
            },
             "Output": "{% $states.result.Payload %}",
            "End": true
        },
        "ChargePayment": {
            "Type": "Task",
            "Resource": "arn:aws:states:::lambda:invoke",
            "Arguments": {
                "FunctionName": "${charge_payment_arn}",
                "Payload": "{% $states.input %}"
            },
            "Next": "ReserveInventory"
        },
        "ReserveInventory": {
            "Type": "Task",
            "Resource": "arn:aws:states:::lambda:invoke",
            "Arguments": {
                "FunctionName": "${reserve_inventory_arn}",
                "Payload": "{% $states.input %}"
            },
            "Next": "Success"
        },
        "Success": {
            "Type": "Succeed"
        }
    },
    "QueryLanguage": "JSONata"
}